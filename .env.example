# RemitFlow frontend environment variables
# Copy this file to .env and adjust as needed.

# Base URL of the RemitFlow backend API
VITE_API_BASE_URL=http://localhost:4000/api

# Stellar network to target ("testnet" or "public").
# The mock build ignores this, but it documents the intended config.
VITE_STELLAR_NETWORK=testnet

# Horizon server URL used by the Stellar SDK.
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Toggle the mock services on/off (the demo always runs mocked).
VITE_USE_MOCKS=true
